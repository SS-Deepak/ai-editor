{
  "elements": [
    {
      "id": "elem_container",
      "type": "container",
      "name": "Container",
      "description": "Generic container/wrapper element",
      "icon": "Square",
      "category": "layout",
      "createdBy": "admin",
      "isPublished": true,
      "defaultProps": {},
      "defaultStyles": {
        "base": {
          "display": "block",
          "width": "100%",
          "padding": "16px"
        }
      },
      "allowChildren": true,
      "propsConfig": []
    },
    {
      "id": "elem_section",
      "type": "section",
      "name": "Section",
      "description": "Full-width section container",
      "icon": "LayoutTemplate",
      "category": "layout",
      "createdBy": "admin",
      "isPublished": true,
      "defaultProps": {},
      "defaultStyles": {
        "base": {
          "display": "block",
          "width": "100%",
          "padding": "64px 24px",
          "backgroundColor": { "$palette": "background" }
        },
        "tablet": {
          "padding": "80px 32px"
        },
        "desktop": {
          "padding": "100px 48px"
        }
      },
      "allowChildren": true,
      "propsConfig": []
    },
    {
      "id": "elem_wrapper",
      "type": "wrapper",
      "name": "Content Wrapper",
      "description": "Max-width centered wrapper",
      "icon": "Columns",
      "category": "layout",
      "createdBy": "admin",
      "isPublished": true,
      "defaultProps": {},
      "defaultStyles": {
        "base": {
          "display": "block",
          "width": "100%",
          "maxWidth": { "$settings": "layout.maxWidth" },
          "marginLeft": "auto",
          "marginRight": "auto",
          "paddingLeft": { "$settings": "spacing.containerPadding.mobile" },
          "paddingRight": { "$settings": "spacing.containerPadding.mobile" }
        },
        "tablet": {
          "paddingLeft": { "$settings": "spacing.containerPadding.tablet" },
          "paddingRight": { "$settings": "spacing.containerPadding.tablet" }
        },
        "desktop": {
          "paddingLeft": { "$settings": "spacing.containerPadding.desktop" },
          "paddingRight": { "$settings": "spacing.containerPadding.desktop" }
        }
      },
      "allowChildren": true,
      "propsConfig": []
    },
    {
      "id": "elem_flexbox",
      "type": "flexbox",
      "name": "Flexbox",
      "description": "Flexible box layout container",
      "icon": "LayoutDashboard",
      "category": "layout",
      "createdBy": "admin",
      "isPublished": true,
      "defaultProps": {
        "direction": "row",
        "justify": "flex-start",
        "align": "stretch",
        "wrap": "nowrap",
        "gap": "16px"
      },
      "defaultStyles": {
        "base": {
          "display": "flex",
          "flexDirection": "row",
          "justifyContent": "flex-start",
          "alignItems": "stretch",
          "flexWrap": "nowrap",
          "gap": "16px"
        }
      },
      "allowChildren": true,
      "propsConfig": [
        {
          "name": "direction",
          "label": "Direction",
          "type": "select",
          "options": [
            { "label": "Row →", "value": "row" },
            { "label": "Row Reverse ←", "value": "row-reverse" },
            { "label": "Column ↓", "value": "column" },
            { "label": "Column Reverse ↑", "value": "column-reverse" }
          ]
        },
        {
          "name": "justify",
          "label": "Justify Content",
          "type": "select",
          "options": [
            { "label": "Start", "value": "flex-start" },
            { "label": "Center", "value": "center" },
            { "label": "End", "value": "flex-end" },
            { "label": "Space Between", "value": "space-between" },
            { "label": "Space Around", "value": "space-around" },
            { "label": "Space Evenly", "value": "space-evenly" }
          ]
        },
        {
          "name": "align",
          "label": "Align Items",
          "type": "select",
          "options": [
            { "label": "Start", "value": "flex-start" },
            { "label": "Center", "value": "center" },
            { "label": "End", "value": "flex-end" },
            { "label": "Stretch", "value": "stretch" },
            { "label": "Baseline", "value": "baseline" }
          ]
        },
        {
          "name": "wrap",
          "label": "Wrap",
          "type": "select",
          "options": [
            { "label": "No Wrap", "value": "nowrap" },
            { "label": "Wrap", "value": "wrap" },
            { "label": "Wrap Reverse", "value": "wrap-reverse" }
          ]
        },
        {
          "name": "gap",
          "label": "Gap",
          "type": "text",
          "placeholder": "e.g., 16px, 1rem"
        }
      ]
    },
    {
      "id": "elem_grid",
      "type": "grid",
      "name": "Grid",
      "description": "CSS Grid layout container",
      "icon": "Grid3x3",
      "category": "layout",
      "createdBy": "admin",
      "isPublished": true,
      "defaultProps": {
        "columns": "3",
        "gap": "24px"
      },
      "defaultStyles": {
        "base": {
          "display": "grid",
          "gridTemplateColumns": "repeat(1, 1fr)",
          "gap": "16px"
        },
        "tablet": {
          "gridTemplateColumns": "repeat(2, 1fr)",
          "gap": "24px"
        },
        "desktop": {
          "gridTemplateColumns": "repeat(3, 1fr)"
        }
      },
      "allowChildren": true,
      "propsConfig": [
        {
          "name": "columns",
          "label": "Columns (Desktop)",
          "type": "select",
          "options": [
            { "label": "1 Column", "value": "1" },
            { "label": "2 Columns", "value": "2" },
            { "label": "3 Columns", "value": "3" },
            { "label": "4 Columns", "value": "4" },
            { "label": "5 Columns", "value": "5" },
            { "label": "6 Columns", "value": "6" }
          ]
        },
        {
          "name": "gap",
          "label": "Gap",
          "type": "text",
          "placeholder": "e.g., 24px, 2rem"
        }
      ]
    },
    {
      "id": "elem_columns",
      "type": "columns",
      "name": "Columns",
      "description": "Two-column layout",
      "icon": "PanelLeftClose",
      "category": "layout",
      "createdBy": "admin",
      "isPublished": true,
      "defaultProps": {
        "layout": "1-1",
        "gap": "32px"
      },
      "defaultStyles": {
        "base": {
          "display": "flex",
          "flexDirection": "column",
          "gap": "24px"
        },
        "tablet": {
          "flexDirection": "row",
          "gap": "32px"
        }
      },
      "allowChildren": true,
      "propsConfig": [
        {
          "name": "layout",
          "label": "Column Ratio",
          "type": "select",
          "options": [
            { "label": "Equal (1:1)", "value": "1-1" },
            { "label": "Left Wide (2:1)", "value": "2-1" },
            { "label": "Right Wide (1:2)", "value": "1-2" },
            { "label": "Left Narrow (1:3)", "value": "1-3" },
            { "label": "Right Narrow (3:1)", "value": "3-1" }
          ]
        },
        {
          "name": "gap",
          "label": "Gap",
          "type": "text",
          "placeholder": "e.g., 32px"
        }
      ]
    },
    {
      "id": "elem_stack",
      "type": "stack",
      "name": "Stack",
      "description": "Vertical stack with consistent spacing",
      "icon": "AlignVerticalSpaceAround",
      "category": "layout",
      "createdBy": "admin",
      "isPublished": true,
      "defaultProps": {
        "gap": "16px",
        "align": "stretch"
      },
      "defaultStyles": {
        "base": {
          "display": "flex",
          "flexDirection": "column",
          "gap": "16px",
          "alignItems": "stretch"
        }
      },
      "allowChildren": true,
      "propsConfig": [
        {
          "name": "gap",
          "label": "Gap",
          "type": "text",
          "placeholder": "e.g., 16px"
        },
        {
          "name": "align",
          "label": "Align Items",
          "type": "select",
          "options": [
            { "label": "Stretch", "value": "stretch" },
            { "label": "Start", "value": "flex-start" },
            { "label": "Center", "value": "center" },
            { "label": "End", "value": "flex-end" }
          ]
        }
      ]
    }
  ]
}

